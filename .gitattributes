# Set default behavior to automatically normalize line endings
* text=auto

# Force text files to use LF (Linux) line endings
*.md text eol=lf
*.py text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Explicitly declare binary files (images/diagrams) that should not be normalized
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
